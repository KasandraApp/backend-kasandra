# Kasandra Backend - Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL - use Render Internal Database URL in production)
DATABASE_URL=postgres://user:password@host:5432/kasandra

# JWT
JWT_SECRET=your-secure-jwt-secret-change-this

# Redis (optional, for rate limiting)
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
FRONTEND_URL=https://kasandra-frontend.vercel.app

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://kasandra-backend.onrender.com/api/v1/auth/google/callback

# SMTP (optional, for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@kasandra.app
